(define Lmax @Lmax@)
(define tSub @tSub@)
(define CSub @CSub@)
(define tAlN @tAlN@)
(define tAl7GaN @tAl7GaN@)
(define xAl7GaN @xAl7GaN@)
(define tAl8GaN @tAl7GaN@)
(define xAl8GaN @xAl8GaN@)
(define cAlGaN 1e14)

(define tHRGaN @tHRGaN@)
(define tTGaN @tTGaN@)

; Using UCS coordinate system for structure generation
(sde:set-process-up-direction "+z")
(sdegeo:set-default-boolean "ABA")
##----substrate--------------------------
(sdegeo:create-rectangle   (position 0 0 0) (position Lmax tSub 0)  "Silicon" "Rsub" )
(sdedr:define-constant-profile "ndop_Rsub" "pSiliconActiveConcentration" CSub)
(sdedr:define-constant-profile-region "Dndop_Rsub" "ndop_Rsub" "Rsub")

(sdegeo:create-rectangle   (position 0 0 0) (position Lmax (- 0 tAlN) 0)   "AlN" "RAlN" )

(sdegeo:create-rectangle   (position 0 (- 0 tAlN) 0) (position Lmax (- 0 tAlN tAl7GaN) 0)   "AlGaN" "AlGaN_1" )
(sdedr:define-constant-profile "ndop_AlGaN_1_const" "nSiliconActiveConcentration" cAlGaN)
(sdedr:define-constant-profile-region "ndop_AlGaN_1_const" "ndop_AlGaN_1_const" "AlGaN_1")
(sdedr:define-constant-profile "xmole_AlGaN_1_const" "xMoleFraction" xAl7GaN)
(sdedr:define-constant-profile-region "xmole_AlGaN_1_const" "xmole_AlGaN_1_const" "AlGaN_1")

(sdegeo:create-rectangle   (position 0 (- 0 tAlN tAl7GaN) 0) (position Lmax (- 0 tAlN tAl7GaN tAl8GaN) 0)   "AlGaN" "AlGaN_2" )
(sdedr:define-constant-profile "ndop_AlGaN_2_const" "nSiliconActiveConcentration" cAlGaN)
(sdedr:define-constant-profile-region "ndop_AlGaN_2_const" "ndop_AlGaN_2_const" "AlGaN_2")
(sdedr:define-constant-profile "xmole_AlGaN_2_const" "xMoleFraction" xAl8GaN)
(sdedr:define-constant-profile-region "xmole_AlGaN_2_const" "xmole_AlGaN_2_const" "AlGaN_2")

(define BRMATERIAL1 "AlGaN")
(define BRMATERIAL2 "AlN")
(define BRLAYER1_THICKNESS 0.03)  
(define BRLAYER2_THICKNESS 0.006)  
(define BRX_MIN 0)
(define BRX_MAX Lmax)
(define BRNUM_PERIODS @SLs1@)       

(define BRPERIOD_LIST 
    (do ((i 0 (+ i 1)) (lst '() (cons i lst)))
        ((= i BRNUM_PERIODS) (reverse lst))))

(define BRY_CURRENT (- 0 tAlN tAl7GaN tAl8GaN))

(for-each
    (lambda (period-index)
        (begin
            (define BRLAYER_NAME1 (string-append BRMATERIAL1 "_BRperiod_" (number->string period-index)))
            (define BRMxmole (string-append "BRMX" BRMATERIAL1 "_BRMX_" (number->string period-index)))
            (define BRRDName1 (string-append BRMATERIAL1 "_BRRD1_" (number->string period-index)))
            (sdegeo:create-rectangle
                (position BRX_MIN BRY_CURRENT 0)
                (position BRX_MAX (- BRY_CURRENT BRLAYER1_THICKNESS) 0)
                BRMATERIAL1 BRLAYER_NAME1)
			(sdedr:define-constant-profile "BRxmole_RM" "xMoleFraction" 0.3)
			(sdedr:define-constant-profile-region BRMxmole "BRxmole_RM" BRLAYER_NAME1)              
			(sdedr:define-constant-profile "BRndop_RM1" "CarbonActiveConcentration" @cCarbon@)
			(sdedr:define-constant-profile-region BRRDName1 "BRndop_RM1" BRLAYER_NAME1)            
            (set! BRY_CURRENT (- BRY_CURRENT BRLAYER1_THICKNESS))
            
            (define BRLAYER_NAME2 (string-append BRMATERIAL2 "_BRperiod_" (number->string period-index)))
            (define BRRDName2 (string-append BRMATERIAL2 "_BRRD2_" (number->string period-index)))
            (sdegeo:create-rectangle
                (position BRX_MIN BRY_CURRENT 0)
                (position BRX_MAX (- BRY_CURRENT BRLAYER2_THICKNESS) 0)
                BRMATERIAL2 BRLAYER_NAME2) 
			(sdedr:define-constant-profile "BRndop_RM2" "CarbonActiveConcentration" @cCarbon@)
			(sdedr:define-constant-profile-region BRRDName2 "BRndop_RM2" BRLAYER_NAME2)   
            (set! BRY_CURRENT (- BRY_CURRENT BRLAYER2_THICKNESS))
        )
    )
    BRPERIOD_LIST
)


(define BR2MATERIAL1 "AlGaN")
(define BR2MATERIAL2 "AlN")
(define BR2LAYER1_THICKNESS 0.03)  
(define BR2LAYER2_THICKNESS 0.006)  
(define BR2X_MIN 0)
(define BR2X_MAX Lmax)
(define BR2NUM_PERIODS @SLs2@)       

(define BR2PERIOD_LIST 
    (do ((i 0 (+ i 1)) (lst '() (cons i lst)))
        ((= i BR2NUM_PERIODS) (reverse lst))))

(define BR2Y_CURRENT (- 0 tAlN tAl7GaN tAl8GaN (* 0.036 BRNUM_PERIODS)))

(for-each
    (lambda (period-index)
        (begin
            (define BR2LAYER_NAME1 (string-append BR2MATERIAL1 "_BR2period_" (number->string period-index)))
            (define BR2Mxmole (string-append "BR2MX" BR2MATERIAL1 "_BR2MX_" (number->string period-index)))            
            (define BR2RDName1 (string-append BR2MATERIAL1 "_BR2RD1_" (number->string period-index)))
            (sdegeo:create-rectangle
                (position BR2X_MIN BR2Y_CURRENT 0)
                (position BR2X_MAX (- BR2Y_CURRENT BR2LAYER1_THICKNESS) 0)
                BR2MATERIAL1 BR2LAYER_NAME1)
			(sdedr:define-constant-profile "BR2xmole_RM" "xMoleFraction" 0.15)
			(sdedr:define-constant-profile-region BR2Mxmole "BR2xmole_RM" BR2LAYER_NAME1)              
			(sdedr:define-constant-profile "BR2ndop_RM1" "CarbonActiveConcentration" @cCarbon@)
			(sdedr:define-constant-profile-region BR2RDName1 "BR2ndop_RM1" BR2LAYER_NAME1)            
            (set! BR2Y_CURRENT (- BR2Y_CURRENT BR2LAYER1_THICKNESS))
            
            (define BR2LAYER_NAME2 (string-append BR2MATERIAL2 "_BR2period_" (number->string period-index)))
            (define BR2RDName2 (string-append BR2MATERIAL2 "_BR2RD2_" (number->string period-index)))
            (sdegeo:create-rectangle
                (position BR2X_MIN BR2Y_CURRENT 0)
                (position BR2X_MAX (- BR2Y_CURRENT BR2LAYER2_THICKNESS) 0)
                BR2MATERIAL2 BR2LAYER_NAME2) 
			(sdedr:define-constant-profile "BR2ndop_RM2" "CarbonActiveConcentration" @cCarbon@)
			(sdedr:define-constant-profile-region BR2RDName2 "BR2ndop_RM2" BR2LAYER_NAME2)   
            (set! BR2Y_CURRENT (- BR2Y_CURRENT BR2LAYER2_THICKNESS))
        )
    )
    BR2PERIOD_LIST
)

(define HR_CURRENT (- 0 tAlN tAl7GaN tAl8GaN (* 0.036 BRNUM_PERIODS) (* 0.036 BR2NUM_PERIODS)))

(sdegeo:create-rectangle    (position 0 HR_CURRENT 0)    (position Lmax (- HR_CURRENT tHRGaN) 0)   "GaN" "RHRGaN")
(sdedr:define-constant-profile "CHRGaN" "CarbonActiveConcentration" 3e19)
(sdedr:define-constant-profile-region "PHRGaN" "CHRGaN" "RHRGaN")  	
	
(sdegeo:create-rectangle    (position 0 (- HR_CURRENT tHRGaN) 0)    (position Lmax (- HR_CURRENT tHRGaN tTGaN) 0)   "GaN" "RTGaN")
(sdedr:define-constant-profile "CTGaN" "nSiliconActiveConcentration" 1e19)
(sdedr:define-constant-profile-region "PTGaN" "CTGaN" "RTGaN")  	


(define anode.metal (sdegeo:create-rectangle  (position (- (/ Lmax 2) 0.5) (- HR_CURRENT tHRGaN tTGaN)  0) (position (+ (/ Lmax 2) 0.5) (- HR_CURRENT tHRGaN tTGaN 0.1)  0)  "Metal" "anode.metal" ))
(define cathode.metal (sdegeo:create-rectangle  (position (- (/ Lmax 2) 0.5) tSub  0) (position (+ (/ Lmax 2) 0.5) (+ tSub 0.1)  0)  "Metal" "cathode.metal" ))

(sdegeo:define-contact-set "anode")
(sdegeo:set-current-contact-set "anode")
(sdegeo:set-contact-boundary-edges anode.metal)
(sdegeo:delete-region anode.metal)
 
(sdegeo:define-contact-set "cathode")
