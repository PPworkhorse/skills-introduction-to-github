(sdegeo:set-contact-boundary-edges cathode.metal)
(sdegeo:delete-region cathode.metal)


(sdedr:define-refeval-window "Pl.global" "Rectangle"
                (position 0 (- HR_CURRENT tHRGaN tTGaN) 0) (position Lmax tSub 0))
(sdedr:define-refinement-size "Ref.global" 0.5 1  0.25 0.5)
(sdedr:define-refinement-placement "Ref.global" "Ref.global" "Pl.global")

(sdedr:define-refeval-window "Pl.global1" "Rectangle"
                (position 0 (- HR_CURRENT tHRGaN tTGaN) 0) (position Lmax tSub 0))
(sdedr:define-refinement-size "Ref.global1" 0.2 0.05 0.1 0.05)
(sdedr:define-refinement-function "Ref.global1" "DopingConcentration" "MaxTransDiff" 1.0)
(sdedr:define-refinement-function "Ref.global1" "MaxLenInt" "AlN" "Silicon" 0.002 2.0 "DoubleSide")
(sdedr:define-refinement-function "Ref.global1" "MaxLenInt" "AlN" "AlGaN" 0.002 2.0 "DoubleSide")
(sdedr:define-refinement-function "Ref.global1" "MaxLenInt" "AlGaN" "GaN" 0.002 2.0 "DoubleSide")
(sdedr:define-refinement-placement "Ref.global1" "Ref.global1" "Pl.global1")

