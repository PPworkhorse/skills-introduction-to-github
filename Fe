*----------------------------------------------------------------------
} * End of Device
*----------------------------------------------------------------------

Math {
	ExitOnFailure
	Transient= BE
	ExtendedPrecision
	NumberOfThreads=4
	Extrapolate(order=2)
	RelErrControl
	DirectCurrent
	RHSmax=1e30
	RHSfactor=1e30
	RHSfactor1=1e30
	Digits = 7
	method=ParDiSO 
	ErrRef(electron)=1e-6
	ErrRef(hole)=1e-6

	RHSMin=1e-20
	eDrForceRefDens=1e5
	hDrForceRefDens=1e5
	Notdamped=20
	Iterations=30
	Traps(damping=0)
	Cylindrical(XAxis=0)
}    

File {
	Output= "@log@"
	ACExtract= "@acplot@"
}


System {
	MOS mos (drain=d source=s gate=g substrate=b Dummy=u)
	Vsource_pset vd ( d 0 ){ dc = 0 }
	Vsource_pset vs ( s 0 ){ dc = 0 }
	Vsource_pset vg ( g 0 ){ dc = 0 }
	Vsource_pset vb ( b 0 ){ dc = 0 }	
	Resistor_pset Ru (u 0) { resistance= 1.0 }	
}


Solve {

	*- Creating initial guess:
	NewCurrentPrefix="n@node@_init"
	Coupled(Iterations= 1000 LineSearchDamping= 1e-8){ Poisson Electron Hole }
	Set (Ru."resistance"= 1e12)	
	Quasistationary(
		InitialStep= 1e-2 Increment= 1.5
		MinStep= 1e-6 MaxStep= 0.1
		Goal { Parameter= vg.dc Voltage= -1 }
	){ Coupled { Poisson Electron Hole } }
	
	NewCurrentPrefix=""
	Quasistationary(
		DoZero
		InitialStep= 1e-2 Increment= 1.5
		MinStep= 1e-6 MaxStep= 0.1
		Goal { Parameter= vg.dc Voltage= 1 }
	){ ACCoupled (
		 StartFrequency= 1e6 EndFrequency= 1e6 NumberOfPoints= 1 Decade
		 Node(d s g b u) Exclude(vd vs vg vb )
		 ACCompute (Time= (Range = (0 1)  Intervals= 40))
		){ Poisson Electron Hole }
	}
}


