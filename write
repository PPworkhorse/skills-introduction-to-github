load_library ifm

#setdep @previous@
set PL @node|Hold_Read_L@
set PR @node|Hold_Read_R@

proc PLOTALL { N P } {

	load_file ${N}_n${P}_sys_des.plt -name D($N)     
                         
	create_plot -1d -name $N
	select_plots $N
	set_plot_prop -plot $N -title "$N" -title_font_size 16 -show_legend

	set_axis_prop -plot $N -axis y  -title "Vout (V)"
	set_axis_prop -plot $N -axis x  -title "Sweep"  
	
	create_curve -name  OL -dataset D($N) -axisX time -axisY v(OL)
	set_curve_prop OL -label "OL" -color red -line_style solid -line_width 3

	create_curve -name  OR -dataset D($N) -axisX time -axisY v(OR)
	set_curve_prop OR -label "OUT" -color red -line_style solid -line_width 3
                                                                               
}  

PLOTALL flipL $PL
PLOTALL flipR $PR

create_plot -1d -name SNM
select_plots SNM
#if @WL@ == 0.8
set_plot_prop -plot SNM -title "READ Butterfly" -title_font_size 16 -show_legend
#elif @WL@ == 0
set_plot_prop -plot SNM -title "HOLD Butterfly" -title_font_size 16 -show_legend
#endif
set CSV_L(Header,0) "Left"
set CSV_L(Data,0)   [get_variable_data v(OR) -dataset D(flipL)]
