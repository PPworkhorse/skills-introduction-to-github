Plot{
  eDensity hDensity
  TotalCurrent/Vector eCurrent/Vector hCurrent/Vector
  eMobility hMobility
  eVelocity hVelocity
  eQuasiFermi hQuasiFermi
  eTemperature Temperature * hTemperature
  ElectricField/Vector Potential SpaceCharge
  Doping DonorConcentration AcceptorConcentration
  SRH Band2Band * Auger
  AvalancheGeneration eAvalancheGeneration hAvalancheGeneration
  eGradQuasiFermi/Vector hGradQuasiFermi/Vector
  eEparallel hEparallel eENormal hENormal
  BandGap 
  BandGapNarrowing
  Affinity
  ConductionBand ValenceBand
  eQuantumPotential hQuantumPotential
  eBarrierTunneling hBarrierTunneling * BarrierTunneling
  eTrappedCharge  hTrappedCharge
}

Math {
  Extrapolate
  RelErrControl
  Digits= 5
  RHSmin= 1e-10
  Notdamped= 50
  Iterations= 20
  ExitOnFailure
  eDrForceRefDens= 1e12
  hDrForceRefDens= 1e12
  TensorGridAniso
  StressMobilityDependence= TensorFactor
#  StressLimit= 4e9  #[Pa]

  Method= ILS
  Number_Of_Threads= 8
  -CheckUndefinedModels	  	  
  
  Surface "s1" (
  MaterialInterface= "HfO2/Oxide" 
  )

  NonLocalPath (
  	  Postprocessing
  	  Derivative= 0                     # compute derivatives
  	  Strategy=1						# use strategy 1
  	  N=5 								# collect edges from last 5 iterations
  	  MinStep=1.0e-5					# define lower boundary
  	  MaxStep=1.0e-2					# define upper boundary
  )  
}

System{
	Vsource_pset  Vdl (DL 0)  { dc= 0.0 }
	Vsource_pset  Vdr (DR 0)  { dc= 0.0 }
	Vsource_pset  Vgl (GL 0)  { dc= 0.0 }
	Vsource_pset  Vgr (GR 0)  { dc= 0.0 }
	Vsource_pset  Vwd (WD 0)  { dc= 0.0 }
	Vsource_pset  Vbl (BL 0)  { dc= 0.0 }
	Vsource_pset  Vbr (BR 0)  { dc= 0.0 }
	Vsource_pset  Vpl (PL 0)  { dc= 0.0 }
	Vsource_pset  Vpr (PR 0)  { dc= 0.0 }
	Resistor_pset Rpl (PL OL) { resistance= 1e12 }
	Resistor_pset Rpr (PR OR) { resistance= 1e12 }
	AMOS  amosL ( "source"=BL "drain"=OL "gate"=WD "substrate"=0)
	AMOS  amosR ( "source"=BR "drain"=OR "gate"=WD "substrate"=0)
	PMOS  pmosL ( "source"=DL "drain"=OL "gate"=OR "substrate"=DL)
	NMOS  nmosL ( "source"=GL "drain"=OL "gate"=OR "substrate"=0)
	PMOS  pmosR ( "source"=DR "drain"=OR "gate"=OL "substrate"=DR)
	NMOS  nmosR ( "source"=GR "drain"=OR "gate"=OL "substrate"=0)
	Plot "n@node@_sys_des.plt"
	(time() v(DR) v(DL) v(WD) v(BR) v(BL) v(OL) v(OR) v(PL) v(PR) v(GR) v(GL)
	        i(Rpl,OL) i(Rpr,OR)
	        i(pmosR,DR) i(amosR,BR) i(nmosR,GR)
	        i(pmosL,DL) i(amosL,BL) i(nmosL,GL))
}

Solve{
	Set (Rpl."resistance"= 1.0)
	Set (Rpr."resistance"= 1e12)
	NewCurrentPrefix="bootL_"
	Coupled(Iterations= 100 LineSearchDamping= 0.01){ Poisson }
	Quasistationary( 
		InitialStep= 1e-3 Increment= 1.35 
		MinStep= 1e-5 MaxStep= 0.1 
		Goal{ Parameter= Vdl.dc Voltage= _Vdd_Supply_ }
		Goal{ Parameter= Vdr.dc Voltage= _Vdd_Supply_ }
		Goal{ Parameter= Vbl.dc Voltage= _Vdd_Supply_ }
		Goal{ Parameter= Vbr.dc Voltage= _Vdd_Supply_ }
		Goal{ Parameter= Vpl.dc Voltage= _Vdd_Supply_ }
		Goal{ Parameter= Vpr.dc Voltage= _Vdd_Supply_ }
	){ Coupled{ Poisson Electron Hole Contact Circuit } }

	Save ( FilePrefix="n@node@_boot" )
# READ
	NewCurrentPrefix="bootL_READ_"
	Quasistationary(
		InitialStep= 1e-3 Increment= 1.35 
		MinStep= 1e-6 MaxStep= 0.1
		Goal{ Parameter= Vwd.dc    Voltage= @WL@ }
	){ Coupled{ Poisson Electron Hole Contact Circuit } }

	Save ( FilePrefix="n@node@_flipL" )
	
	Load ( FilePrefix="n@node@_flipL" )
# Left inverter voltage transfer characteristic (VTC)
	NewCurrentPrefix="flipL_"
	Quasistationary( 
		InitialStep= 1e-3 Increment= 1.35 
		MinStep= 1e-6 MaxStep= 0.025
		Goal{ Parameter= Vpl.dc  Voltage=  0.0 }
	){ ACCoupled (
		StartFrequency= 0 EndFrequency= 0
		NumberOfPoints= 1 Decade
		Node(OL OR)
		ObservationNode(OR)
		Exclude(Vpl Vpr)
		ACExtract= "n@node@_sram"
		* NoisePlot= "n@node@_noise"
##		ACcompute(   Time = (
##		Range = (0.00 0.30) intervals= 10;
##		Range = (0.30 0.70) intervals= 40;
##		Range = (0.70 1.00) intervals= 10) )
	){ Poisson Electron Hole Contact Circuit }
##		CurrentPlot( Time = (
##		Range = (0.00 0.30) intervals= 10;
##		Range = (0.30 0.70) intervals= 40;
##		Range = (0.70 1.00) intervals= 10) )
	}	
	
}


