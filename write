System{
	Vsource_pset  Vdl (DL 0)  { dc= 0.0 }
	Vsource_pset  Vdr (DR 0)  { dc= 0.0 }
	Vsource_pset  Vgl (GL 0)  { dc= 0.0 }
	Vsource_pset  Vgr (GR 0)  { dc= 0.0 }
	Vsource_pset  Vwd (WD 0)  { dc= 0.0 }
	Vsource_pset  Vbl (BL 0)  { dc= 0.0 }
	Vsource_pset  Vbr (BR 0)  { dc= 0.0 }                                                                                   
#	Vsource_pset  Vpl (OL 0)  { dc= 0.0 }
#	Vsource_pset  Vpr (OR 0)  { dc= 0.0 }
	Resistor_pset Rpl (AL OL) { resistance= 1e12 }
	Resistor_pset Rpr (AR OR) { resistance= 1e12 }
	Vsource_pset  Val (AL 0)  { dc= 0.0 }
	Vsource_pset  Var (AR 0)  { dc= 0.0 }	
	
	AMOS  amosL ( "source"=BL "drain"=OL "gate"=WD "substrate"=0)
	AMOS  amosR ( "source"=BR "drain"=OR "gate"=WD "substrate"=0)
	PMOS  pmosL ( "source"=DL "drain"=OL "gate"=OR "substrate"=DL)
	NMOS  nmosL ( "source"=GL "drain"=OL "gate"=OR "substrate"=0)
	PMOS  pmosR ( "source"=DR "drain"=OR "gate"=OL "substrate"=DR)
	NMOS  nmosR ( "source"=GR "drain"=OR "gate"=OL "substrate"=0)
	Plot "n@node@_sys_des.plt"
	(time() v(DR) v(DL) v(WD) v(BR) v(BL) v(OL) v(OR) v(GR) v(GL)
	        i(Rpl,OL) i(Rpr,OR)
	        i(pmosR,DR) i(amosR,BR) i(nmosR,GR)
	        i(pmosL,DL) i(amosL,BL) i(nmosL,GL))
}

Solve{	                                                        
	Set (Rpl."resistance"= 1.0)
	Set (Rpr."resistance"= 1e12)
	NewCurrentPrefix="bootL_"
	Coupled(Iterations= 100 LineSearchDamping= 0.01){ Poisson }
	Quasistationary( 
		InitialStep= 1e-3 Increment= 1.35 
		MinStep= 1e-5 MaxStep= 0.1 
		Goal{ Parameter= Vdl.dc Voltage= _Vdd_Supply_ }
		Goal{ Parameter= Vdr.dc Voltage= _Vdd_Supply_ }
		Goal{ Parameter= Vbl.dc Voltage= _Vdd_Supply_ }
		Goal{ Parameter= Vbr.dc Voltage= _Vdd_Supply_ }
		Goal{ Parameter= Val.dc Voltage= _Vdd_Supply_ }
		Goal{ Parameter= Var.dc Voltage= _Vdd_Supply_ }
	){ Coupled{ Poisson Electron Hole Contact Circuit } }

	Save ( FilePrefix="n@node@_boot" )
# WRITE
	NewCurrentPrefix="bootL_WRITE_"
	Quasistationary(
		InitialStep= 1e-3 Increment= 1.35 
		MinStep= 1e-6 MaxStep= 0.1
		Goal{ Parameter= Vwd.dc    Voltage= @WL@ }
	){ Coupled{ Poisson Electron Hole Contact Circuit } }

	Save ( FilePrefix="n@node@_flipL" )	

	Load ( FilePrefix="n@node@_flipL" )

	Set (Rpl."resistance"= 1e12)
	Set (Rpr."resistance"= 1e12)                                     
             
	NewCurrentPrefix="WRITE_"   		
	Quasistationary( 
		InitialStep= 1e-3 Increment= 1.5
		MinStep= 1e-20 MaxStep= 0.05
	Goal{ Parameter= Vbl.dc  Voltage=  0.0 }    
##	){ Coupled (LineSearchDamping= 0.01 Iterations= 50) { Poisson Electron Hole Contact Circuit } 
	){ Poisson Electron Hole Contact Circuit } 
