File {
  Grid      = "@tdr@"	  
  Parameter = "@parameter@"
  Plot      = "@tdrdat@"
  Current   = "@plot@"
  Output    = "@log@"
	
}

Electrode {

{Name= "source" Voltage=0}
{Name= "source1" Voltage=0}
{Name= "gate" Voltage=0}
{Name= "drain" Voltage=0}

}

Physics(MaterialInterface="Silicon/Oxide") {Charge(Conc=4.5e10)}

Physics {

	Temperature = 300
	Mobility(
		PhuMob Enormal
		HighFieldSaturation
	)
	Recombination(
		SRH( DopingDep TempDependence)	
		Auger
    Avalanche(Okuto)
    )
EffectiveIntrinsicDensity( OldSlotboom )

}

Plot{
  eDensity hDensity
  TotalCurrent/Vector eCurrent/Vector hCurrent/Vector
  eMobility hMobility
  eVelocity hVelocity
  eQuasiFermi hQuasiFermi
  Temperature
  eTemperature  hTemperature
  ElectricField/Vector Potential SpaceCharge
  Doping DonorConcentration AcceptorConcentration
  SRH Auger Band2Band 
  AvalancheGeneration eAvalancheGeneration hAvalancheGeneration
  eGradQuasiFermi/Vector hGradQuasiFermi/Vector
  eEparallel hEparallel eENormal hENormal
  BandGapNarrowing
}

Math {
	RelErrControl
	ExtendedPrecision
	Extrapolate                               
	Notdamped= 50
	Iterations= 20
	ExitOnFailure
	Digits= 5 
	RHSmin= 1e-10
	# RefDens_eGradQuasiFermi_EParallelToInterface= 1.0e12
	# RefDens_hGradQuasiFermi_EParallelToInterface= 1.0e12
	Number_of_threads= 8

}


Solve {

	## Initial Solution
	Coupled(Iterations=100 LineSearchDamping=1e-4){ Poisson }
	Coupled(Iterations=100 LineSearchDamping=1e-4){ Poisson Electron }
	Coupled(Iterations=100 LineSearchDamping=1e-4){Poisson Electron Hole}   
	
	NewCurrentPrefix="BV_"
	
	## Ramp drain voltage until the device drain current exceeds 250 uA 
	Quasistationary(
	InitialStep= 1e-3 MinStep= 1e-12 MaxStep= 1
	Increment= 1.3 Decrement= 2
	Goal { Name="drain" Voltage= 200 }
	BreakCriteria {Current (Contact="drain" Absval= 1e-12) }     
	){ Coupled { Poisson Electron Hole } 
	Plot ( FilePrefix = "n@node@_50" when ( Contact = drain Voltage = 50 ) NoOverwrite )
	Plot ( FilePrefix = "n@node@_80" when ( Contact = drain Voltage = 80 ) NoOverwrite )
	}   

}
