#define _Device_ nmos
#define _SIGN_   1.0
#define _CAR_    Electron Hole
#define _IALM_   IALMob(AutoOrientation)

#define _Vdd_    @Vdd@	
#define _VdLin_  @Vdlin@
#define _VdSat_  @Vdd@



File {
	* input files:
	Grid=       "@tdr@"
	Piezo=      "@tdr@"
	Parameters= "@parameter@"
	* output files:
	Plot=       "@tdrdat@"
	Current=    "@plot@"
	Output=     "@log@"
}

Electrode {
	{ Name= "source"    Voltage= 0.0   }
	{ Name= "drain"     Voltage= 0.0   }
	{ Name= "gate"      Voltage= 0.0 barrier= -0.845 }
	{ Name= "Substrate" Voltage= 0.0   }
}



Physics {
	Temperature= 300
	AreaFactor= 1.0
	Fermi
}

Physics (Material="Silicon") {
	Mobility (
	  Enormal (_IALM_) 
	  HighFieldSaturation
	)
    EffectiveIntrinsicDensity(OldSlotboom)
      
    Recombination(
    SRH( DopingDependence TempDependence)
    Auger
    Band2Band(Model=Hurkx)
    Avalanche(Okuto)
    )     
}


Plot{
	eDensity hDensity
	TotalCurrent/Vector eCurrent/Vector hCurrent/Vector
	eMobility hMobility
	eVelocity hVelocity
	eQuasiFermi hQuasiFermi
	eTemperature hTemperature Temperature
	ElectricField/Vector Potential SpaceCharge
	Doping DonorConcentration AcceptorConcentration
	Band2Band SRH Auger
	AvalancheGeneration eAvalancheGeneration hAvalancheGeneration
	eGradQuasiFermi/Vector hGradQuasiFermi/Vector
	eEparallel hEparallel eENormal hENormal
	BandGap
	BandGapNarrowing
	Affinity
	ConductionBand ValenceBand
	eTrappedCharge hTrappedCharge
	*--Stress related data
	StressXX StressYY StressZZ StressXY StressXZ StressYZ
	eMobilityStressFactorXX eMobilityStressFactorYY eMobilityStressFactorZZ
	eMobilityStressFactorXY eMobilityStressFactorXZ eMobilityStressFactorXY
	hMobilityStressFactorXX hMobilityStressFactorYY hMobilityStressFactorZZ
	hMobilityStressFactorYZ hMobilityStressFactorXZ hMobilityStressFactorXY
}


Math {
  Extrapolate
  RelErrControl
  Digits= 5
  Notdamped= 50
  Iterations= 15
  RHSmin= 1e-8
  Method= Pardiso	  
  DirectCurrent
  ExitOnFailure
  TensorGridAniso
  StressMobilityDependence = TensorFactor
  Number_of_Threads= 8 
  RefDens_eGradQuasiFermi_Zero= 1e12
  RefDens_hGradQuasiFermi_Zero= 1e12
  -CheckUndefinedModels	  
	* Please uncomment if you have 4 CPUs or more
	Number_of_Threads= 4
}

Solve {
	*- Creating initial guess:
	NewCurrentPrefix="n@node@_init"
	Coupled(Iterations= 1000 LineSearchDamping= 1e-8){ Poisson }
	Coupled { Poisson _CAR_ }

	*- Ramp to drain to Vd
	Quasistationary(
		InitialStep= 1e-2 Increment= 1.35
		MinStep= 1e-6 MaxStep= 0.2
		Goal { Name="drain" Voltage= @<_SIGN_*Vdlin>@ }
	){ Coupled { Poisson Electron Hole  } }
	
	*- Vg sweep
	NewCurrentPrefix=""
	Quasistationary(
		DoZero
		InitialStep= 1e-3 Increment= 1.35
		MinStep= 1e-6 MaxStep= 0.02
		Goal { Name="gate" Voltage= @<_SIGN_*Vdd>@ }
	){ Coupled { Poisson Electron Hole }
		CurrentPlot( Time=(Range=(0 1) Intervals= 500)  )
	}
}
