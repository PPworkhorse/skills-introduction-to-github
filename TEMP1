#define _Vdd_    @Vdd@	
#define _VdLin_  @Vdlin@
#define _VdSat_  @Vdd@


File {
  Grid      = "@tdr@"
  
  Parameter = "@parameter@"
  Plot      = "@tdrdat@"
  Current   = "@plot@"
  Output    = "@log@"
  
}

Electrode {
  { Name="source"    Voltage=0.0 }
  { Name="drain"     Voltage=0.0 }
  { Name="gate"      Voltage=0.0 barrier= 0.15}
  { Name="substrate" Voltage=0.0 }
}

Physics { 
         Fermi
         Hydrodynamic(eTemperature)   
         AreaFactor= @Gate_Width@
}

Physics (Material= Silicon) {
	                         
	Mobility (
	  Enormal (IALMob(AutoOrientation)) 
	  HighFieldSaturation
	)
     Recombination(SRH Auger Band2Band Avalanche)
#      Recombination(SRH )
      EffectiveIntrinsicDensity(OldSlotboom)

    Piezo(
    Model(
      Mobility(
         eSubBand(Doping) 
         hSixBand(Doping)
              )
         )
         )	                                
}      
      

Plot{
  eDensity hDensity
  TotalCurrent/Vector eCurrent/Vector hCurrent/Vector
  eMobility hMobility                        
  eVelocity hVelocity
  eQuasiFermi hQuasiFermi
  eTemperature Temperature * hTemperature
  ElectricField/Vector Potential SpaceCharge
  Doping DonorConcentration AcceptorConcentration
  SRH Band2Band Auger
  AvalancheGeneration eAvalancheGeneration hAvalancheGeneration
  eGradQuasiFermi/Vector hGradQuasiFermi/Vector
  eEparallel hEparallel eENormal hENormal
  BandGap 
  BandGapNarrowing
  Affinity
  ConductionBand ValenceBand
  eBarrierTunneling hBarrierTunneling * BarrierTunneling
  eTrappedCharge  hTrappedCharge                                  
  eGapStatesRecombination hGapStatesRecombination
  StressXX StressYY StressZZ StressXY StressXZ StressYZ
  eMobilityStressFactorXX eMobilityStressFactorYY eMobilityStressFactorZZ
  eMobilityStressFactorXY eMobilityStressFactorXZ eMobilityStressFactorXY
  hMobilityStressFactorXX hMobilityStressFactorYY hMobilityStressFactorZZ
  hMobilityStressFactorYZ hMobilityStressFactorXZ hMobilityStressFactorXY
  
}

Math {
  Extrapolate
  Derivatives
  RelErrControl
  Digits=6
  RHSmin=1e-10
  Notdamped=100
  Iterations=50
  DirectCurrent
  ExitOnFailure
  TensorGridAniso
  StressMobilityDependence= TensorFactor 
  * Please uncomment if you have 8 CPUs or more
  NumberOfThreads= 8
  
}

Solve {
  Coupled ( Iterations=100 LineSearchDamping=1e-8 ){ Poisson  }
  Coupled { Poisson Electron Hole eTemperature }
  
  #-- Ramp drain to VdLin
  Quasistationary( 
    InitialStep=1e-2 Increment=1.5 
    MinStep=1e-6 MaxStep=0.1 
    Goal { Name="drain" Voltage=_VdLin_ } 
  ){ Coupled { Poisson Electron Hole eTemperature } }
  Save ( FilePrefix="n@node@_VdLin" )

  #-- Ramp drain to VdSat
  Quasistationary( 
    InitialStep=1e-2 Increment=1.5 
    MinStep=1e-6 MaxStep=0.1 
    Goal { Name="drain" Voltage=_VdSat_ } 
  ){ Coupled { Poisson Electron Hole eTemperature } }
  Save ( FilePrefix="n@node@_VdSat" )

  #-- Vg sweep for Vd=VdLin
  NewCurrentPrefix="IdVg_VdLin_" 
  Load ( FilePrefix = "n@node@_VdLin" )
  Quasistationary( 
    DoZero 
    InitialStep=1e-2 Increment=1.35 
    MinStep=1e-8 MaxStep=0.05 
    Goal { Name="gate" Voltage=_Vdd_ } 
  ){ Coupled { Poisson Electron Hole eTemperature } }

  #-- Vg sweep for Vd=VdSat
  NewCurrentPrefix="IdVg_VdSat_" 
  Load ( FilePrefix="n@node@_VdSat" )
  Quasistationary( 
    DoZero 
    InitialStep=1e-2 Increment=1.35 
    MinStep=1e-8 MaxStep=0.05 
    Goal { Name="gate" Voltage=_Vdd_ } 
  ){ Coupled { Poisson Electron Hole eTemperature } }
}
