;define parameter
(define Lg @Gate_Len@)
(define Lspa @Spacer_Len@)
(define Lsd 0.068)
(define Tox @Tox@)
(define Tpoly 0.03)

(define Xgox (- 0 Tox))
(define Xpoly (- Tox Tpoly))

(define Ymin (- 0 (+ (/ Lg 2) (+ Lspa Lsd)) ))
(define Ymax (+ 0 (+ (/ Lg 2) (+ Lspa Lsd)) ))
(define Yspl  (- 0 (+ (/ Lg 2) Lspa)))
(define Yspr  (+ 0 (+ (/ Lg 2) Lspa)))
(define Ygl  (- 0 (/ Lg 2) ))
(define Ygr  (+ 0 (/ Lg 2) ))
	
; Creating rectangular regions  
(sdegeo:create-rectangle
  (position 0.0 Ymin   0.0) (position 0.2 Ymax   0.0) 
  "Silicon" "R.Sub" ) 
(sdegeo:create-rectangle
  (position Xgox Ygl 0.0) (position 0.0 Ygr   0.0) 
  "Oxide" "R.Gateox" ) 
(sdegeo:set-default-boolean "BAB")
(sdegeo:create-rectangle   
  (position Xpoly Yspl   0.0) (position 0.0 Yspr 0.0) 
  "Nitride" "R.Spacer" )    
(sdegeo:set-default-boolean "ABA")
(sdegeo:create-rectangle                                               
  (position Xpoly Ygl   0.0) (position Xgox Ygr 0.0) 
  "PolySilicon" "R.Polygate" )

; Rounding edges                                            
(sde:define-parameter "fillet-radius" 0.01 0.0 0.0 )
(sdegeo:fillet-2d (find-vertex-id (position Xpoly Yspl 0.0)) fillet-radius)
(sdegeo:fillet-2d (find-vertex-id (position Xpoly Yspr 0.0)) fillet-radius)

;-------------------------------------------------------------------------------
;-- Specification of doping profiles to be inluded during meshing --------------
;-------------------------------------------------------------------------------

; Defining constant doping levels in a region
(sdedr:define-constant-profile "Const.Poly" "ArsenicActiveConcentration" @Poly_Doping@)
(sdedr:define-constant-profile-region "PlaceCD.Poly" "Const.Poly" "R.Polygate")

(sdedr:define-constant-profile "SS.Sub" "Stress" @Stress@)
(sdedr:define-constant-profile-region "SSCD.Sub" "SS.Sub" "R.Sub")

(sdedr:define-refeval-window "BaseLine.Well" 
  "Line" (position 0.0 Ymin 0.0) (position 0.0 Ymax 0.0))

(sdedr:define-gaussian-profile "Gauss.Well"                        
  "BoronActiveConcentration" "PeakPos" @Well_Pos@ "PeakVal" @Well_Peak@
  "ValueAtDepth" 5e16 "Depth" @Well_Depth@ "Gauss" "Factor" 0.5)

(sdedr:define-analytical-profile-placement "PlaceAP.Well"
  "Gauss.Well" "BaseLine.Well" "Both" "NoReplace" "Eval")

; Defining analytic doping profiles
; Step 1: base line definitions
(sdedr:define-refeval-window "BaseLine.Source" 
  "Line" (position 0.0 Ymin 0.0) (position 0.0 (- Yspl 0.005) 0.0))
(sdedr:define-refeval-window "BaseLine.Drain" 
  "Line" (position 0.0 (+ Yspr 0.005) 0.0) (position 0.0 Ymax 0.0))

(sdedr:define-refeval-window "BaseLine.SourceExt" 
  "Line" (position 0.0 Ymin 0.0) (position 0.0 (- Ygl 0.005) 0.0))
(sdedr:define-refeval-window "BaseLine.DrainExt" 
  "Line" (position 0.0 (+ Ygr 0.005) 0.0) (position 0.0 Ymax 0.0))

(sdedr:define-refeval-window "BaseLine.SourceHALO" 
  "Line" (position 0.0 Ymin 0.0) (position 0.0 (- Yspl 0.00) 0.0))
(sdedr:define-refeval-window "BaseLine.DrainHALO" 
  "Line" (position 0.0 (+ Yspr 0.0) 0.0) (position 0.0 Ymax 0.0))

; Step 2: Profile and placement definitions
(sdedr:define-analytical-profile-placement "PlaceAP.Source"
  "Gauss.SourceDrain" "BaseLine.Source" "Negative" "NoReplace" "Eval")

(sdedr:define-gaussian-profile "Gauss.SourceDrain"
  "ArsenicActiveConcentration" "PeakPos" 0.0 "PeakVal" @SD_Peak@
  "ValueAtDepth" 4e17 "Depth" @SD_Depth@ "Gauss" "Factor" 0.05)

(sdedr:define-analytical-profile-placement "PlaceAP.Drain"
  "Gauss.SourceDrain" "BaseLine.Drain" "Negative" "NoReplace" "Eval")

(sdedr:define-analytical-profile-placement "PlaceAP.SourceExt"
  "Gauss.SourceDrainExt" "BaseLine.SourceExt" "Negative" "NoReplace" "Eval")

(sdedr:define-gaussian-profile "Gauss.SourceDrainExt"
  "ArsenicActiveConcentration" "PeakPos" 0.0 "PeakVal" @LDD_Peak@
  "ValueAtDepth" 4e17 "Depth" @LDD_Depth@ "Gauss" "Factor" @LDD_Factor@)

(sdedr:define-analytical-profile-placement "PlaceAP.DrainExt"
  "Gauss.SourceDrainExt" "BaseLine.DrainExt" "Negative" "NoReplace" "Eval")

(sdedr:define-analytical-profile-placement "PlaceAP.SourceHALO"
  "Gauss.SourceDrainHALO" "BaseLine.SourceHALO" "Both" "NoReplace" "Eval")

(sdedr:define-gaussian-profile "Gauss.SourceDrainHALO"
  "BoronActiveConcentration" "PeakPos" @Halo_Pos@ "PeakVal" @Halo_Peak@
  "ValueAtDepth" 4e17 "Depth" @Halo_Depth@ "Gauss" "Factor" @Halo_Factor@)

(sdedr:define-analytical-profile-placement "PlaceAP.DrainHALO"
  "Gauss.SourceDrainHALO" "BaseLine.DrainHALO" "Both" "NoReplace" "Eval")
##--------------------------------------------------------------------------
; Defining contacts 

(sdegeo:set-contact (find-edge-id (position 0.0 (+ Ymin (* Lsd 0.5)) 0.0)) "source")
(sdegeo:set-contact (find-edge-id (position 0.0 (- Ymax (* Lsd 0.5)) 0.0)) "drain")
(sdegeo:set-contact (find-edge-id (position Xpoly 0.0 0.0)) "gate")
(sdegeo:set-contact (find-edge-id (position 0.2 0.0 0.0)) "substrate")

;-------------------------------------------------------------------------------
;-- Specify mesh refinements ---------------------------------------------------
;-------------------------------------------------------------------------------

; Defining regional refinements
;-- epi layer                                         
(sdedr:define-refinement-size "RefDef.Sub" 0.01 0.01 0.01 0.02)                 
(sdedr:define-refinement-function "RefDef.Sub" 
  "DopingConcentration" "MaxTransDiff" 1) 
(sdedr:define-refinement-region "PlaceRF.Sub" "RefDef.Sub" "R.Sub")
(sdedr:define-refinement-function "RefDef.Sub" "MaxLenInt" "R.Sub" 
  "R.Gateox" 0.0002 1.3 "DoubleSide" "UseRegionNames")
;--SD region
(sdedr:define-refeval-window "RefWin.d" 
  "Rectangle" (position 0.0 (- Ygr 0.03) 0.0) (position 0.1 Ymax 0.0))
(sdedr:define-refinement-size "RefDef.d" 0.005 0.005 0.0025 0.0025)
(sdedr:define-refinement-placement "PlaceRF.d" "RefDef.d" 
  "RefWin.d") 
                                                                                   
(sdedr:define-refeval-window "RefWin.s" 
  "Rectangle" (position 0.0 (+ Ygl 0.03) 0.0) (position 0.1 Ymin 0.0))     
(sdedr:define-refinement-size "RefDef.s" 0.005 0.005 0.0025 0.0025)                         
(sdedr:define-refinement-placement "PlaceRF.s" "RefDef.s" 
  "RefWin.s")                                                                   
                                                                                              
;-- channel
(sdedr:define-refeval-window "RefWin.channel"                   
  "Rectangle" (position 0.0 (- Yspl 0.01) 0.0) (position 0.1 (+ Yspr 0.01) 0.0))          
(sdedr:define-refinement-size "RefDef.channel" 0.002 0.002 0.001 0.001)     
(sdedr:define-refinement-placement "PlaceRF.channel" "RefDef.channel" 
  "RefWin.channel") 
