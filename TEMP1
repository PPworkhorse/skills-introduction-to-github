#header


#endheader

fset Fastmode 0
if { $Fastmode == 1} {
    pdbSet ImplantData NoImplant 1
    pdbSet Diffuse NoDiffusionReaction 1
}

AdvancedCalibration

# pdb settings ---------------------------------------------------------
pdbSet InfoDefault 1
pdbSet Diffuse minT 600.0 
pdbSet Mechanics StressHistory 1
pdbSet Mechanics EtchDepoRelax 0

pdbSet ImplantData LeftBoundary Reflect
pdbSet ImplantData RightBoundary Reflect
pdbSet ImplantData BackBoundary Reflect
pdbSet ImplantData FrontBoundary Reflect
pdbSet ImplantData DoseControl BeamDose

#rem # Parallel simulation strategy and unified coordinate system
math numThreads= 8
math coord.ucs

#rem #---------------------------------------------------------------------#
#rem #   START SIMULATION 
#rem #---------------------------------------------------------------------#
line x location= 0.0 tag= top
line x location= 4.6 tag= bottom

line y location= 0.0    tag= left
line y location= 4.45   tag= right

region Silicon substrate xlo= top xhi= bottom ylo= left yhi= right
init Silicon field= Boron resistivity= 45 wafer.orient= {0 0 1} flat.orient= {1 1 0} !DelayFullD

# meshing strategy ----------------------------------------------------------------------
grid set.min.normal.size= 0.001 \
     set.normal.growth.ratio.2d= 2.0 \
     set.max.points= 10000000 set.max.neighbor.ratio= 1e6

refinebox name=Global_Si Silicon       \
    min= "0 0" max= "5 4.45"  \
    xrefine= "0.02 1.0 0.1"                   \
    yrefine= "0.4"

grid remesh 

#split @TU@
transform flip
deposit material= {Silicon} type= isotropic  thickness= 0.5 fields.values= { Phosphorus= 1e18 }
struct tdr= n@node@_A FullD
transform flip

deposit material= {Oxide} type= isotropic  thickness= 0.034

#mask name= TU segments= { 0 1.75 3.95 4.45 }
mask name= TU1 segments= { 1.784 4.45 } negative
photo mask= TU1 thickness= 0.1

etch material= { Oxide } type= directional rate= {0.1} time= 1 \
					   direction= { 1 -1 0 }
					   
strip Photoresist

mask name= TU2 segments= { 3.95 4.45 } 
photo mask= TU2 thickness= 0.1
etch material= { Oxide } type= anisotropic thickness= 0.1
strip Photoresist

#split @WELL@

refinebox name= WELL Silicon       \
    min= "0 0" max= "5 4.45"  \
    xrefine= "0.02 0.2 "                   \
    yrefine= "0.2 0.1 0.2"

grid remesh 

deposit material= {Oxide} type= isotropic  thickness= 0.011

## ---------- well and Vt adjustment implant and anneal -----------------------
mask name= PWELL left= 0 right= 1.5 negative
photo mask= PWELL thickness= 5.0
struct tdr= n@node@_PWPR FullD
implant Phosphorus dose= 1.0e12 energy= 1500 tilt= 0.0
implant Boron dose= 2.0e12 energy= 200 tilt= 0.0
implant Boron dose= @dPW@ energy= 30 tilt= 0.0

strip Photoresist

mask name= NWELL left= 1.4 right= 4.45 negative
photo mask= NWELL thickness= 3.0
struct tdr= n@node@_NWPR FullD
implant Phosphorus dose= 1.5e13 energy= 460 tilt= 0.0
implant Phosphorus dose= 5.0e12 energy= 230 tilt= 0.0
implant Phosphorus dose= 2.4e12 energy= 50 tilt= 0.0

strip Photoresist
 
temp_ramp name= well time= 0.03  temp= 600.0  ramprate= 250.0
temp_ramp name= well time= 10<s> temp= 1020.0 ramprate= 0.0
temp_ramp name= well time= 0.083 temp= 1020.0 ramprate= -90.0

diffuse stress.relax temp_ramp= well

#split @POLY@
etch material= {Oxide} type= isotropic  thickness= 0.011
## ---------- gate oxide --------------------------------------
deposit material= {Oxide} type= isotropic rate= 0.013 time= 1.0 

temp_ramp name= gateox time= 24    temp= 600.0 ramprate= 0.0972
temp_ramp name= gateox time= 20    temp= 740.0 ramprate= 0.0
temp_ramp name= gateox time= 0.093 temp= 740.0 ramprate= -25.0

diffuse stress.relax temp_ramp= gateox


## ---------- poly silicon deposition and etching ---------------
deposit material= {Poly} type= isotropic  thickness= 0.2
implant Boron dose= 1.5e14 energy= 10 tilt= 0.0

mask name= GATE segments= { 0 1.0 2.15 4.45}
photo mask= GATE thickness= 0.2

etch  material= {Poly} type= anisotropic rate= 0.25 time= 1.0

strip Photoresist


## ---------- reoxidation -----------------------------------------
deposit material= {Oxide} type= isotropic rate= {1.0} time= 0.01

temp_ramp name= polyreox time= 0.0667 temp= 600.0 ramprate= 50.0
temp_ramp name= polyreox time= 0.0667 temp= 800.0 ramprate= 25.0
temp_ramp name= polyreox time= 0.0833 temp= 900.0 ramprate=  0.0
temp_ramp name= polyreox time= 0.0667 temp= 900.0 ramprate= -25.0
temp_ramp name= polyreox time= 0.0667 temp= 800.0 ramprate= -50.0

diffuse stress.relax temp_ramp= polyreox

#split @SPA@

deposit material= { Oxide }   type= isotropic   thickness= 0.015
deposit material= { Nitride } type= isotropic   thickness= 0.03
deposit material= { Oxide }   type= isotropic   thickness= 0.1

etch material= { Oxide }   type= anisotropic   thickness= 0.1*1.6
etch material= { Nitride } type= anisotropic   thickness= 0.03*1.8
etch material= { Oxide }   type= anisotropic   thickness= 0.015*1.05

etch material= { Oxide }   type= anisotropic   thickness= 0.015

#split @SD@

refinebox name= SD Silicon       \
    min= "0 0" max= "0.3 1"  \
    xrefine= "0.01 0.02 "                   \
    yrefine= "0.1 0.05 0.1"

grid remesh 

mask name= NP segments= { 0.0 0.5 }
mask name= PP segments= { 0.0 0.5 2.2 3.95 4.45}  negative

photo mask= NP thickness= 1.0
struct tdr= n@node@_NPPR FullD
implant Phosphorus dose= 1.1e14 energy= 75 tilt= 40 rotation= 45 mult.rot= 4
implant Arsenic    dose= 6.0e15 energy= 50 tilt= 0.0
implant Phosphorus dose= 2.0e14 energy= 40 tilt= 0.0

strip Photoresist


temp_ramp name= SDN time= 0.03  temp= 600.0  ramprate= 250.0
temp_ramp name= SDN time= 20<s> temp= 1020.0 ramprate= 0.0
temp_ramp name= SDN time= 0.083 temp= 1020.0 ramprate= -90.0

diffuse stress.relax temp_ramp= SDN

photo mask= PP thickness= 1.0
struct tdr= n@node@_PPPR FullD
implant Boron dose= 6.0e13 energy= 25.0 tilt= 30 rotation= 45  mult.rot= 4
implant Boron dose= 3.2e15 energy= 5.0 tilt= 0 
implant Boron dose= 3.0e13 energy= 15.0 tilt= 0 

strip Photoresist

deposit material= { Oxide }   type= isotropic   thickness= 0.15

temp_ramp name= SDP time= 0.03  temp= 600.0  ramprate= 250.0
temp_ramp name= SDP time= 10<s> temp= 1035.0 ramprate= 0.0
temp_ramp name= SDP time= 0.083 temp= 1035.0 ramprate= -90.0

diffuse stress.relax temp_ramp= SDN

#split @ILD@

deposit material= { Oxide } type= fill   coord= -0.7

mask name= FP segments= { 0.0 2.36 3.06 4.45 } negative
photo mask= FP thickness= 0.5
etch material= { Oxide } type= anisotropic   thickness= 0.56

strip Photoresist

deposit material= { Tungsten } type= fill   coord= -0.7

mask name= CT segments= { 0.0 0.15 0.35 0.65 0.85 4.1 4.3 4.45} negative
photo mask= CT thickness= 0.5
etch material= { Oxide } type= anisotropic   thickness= 1.0
strip Photoresist

deposit material= { Tungsten } type= fill   coord= -0.75

mask name= MFP segments= { 0.0 0.15 0.35 0.65 3.06 4.1 4.3 4.45 }
photo mask= MFP thickness= 0.5
etch material= { Tungsten } type= anisotropic   thickness= 0.05
strip Photoresist

deposit material= { Oxide } type= fill   coord= -0.75

#split @MESH@
##---------------Remeshing for device simulation--------##
# clear the process simulation mesh
refinebox clear
refinebox !keep.lines
line clear
# reset default settings for adaptive meshing
pdbSet Grid AdaptiveField Refine.Abs.Error 1e37
pdbSet Grid AdaptiveField Refine.Rel.Error 1e10
pdbSet Grid AdaptiveField Refine.Target.Length 100.0

# Set high quality delaunay meshes
pdbSet Grid sMesh 1
pdbSet Grid SnMesh DelaunayType boxmethod
pdbSet Grid SnMesh CoplanarityAngle 179
pdbSet Grid SnMesh MaxPoints 500000
pdbSet Grid SnMesh MaxNeighborRatio 1e6

# Set the interface spacing
pdbSet Grid SnMesh max.box.angle.2d 179
grid adaptive set.min.normal.size= 0.001 \
     set.normal.growth.ratio.2d= 2.0 \
     set.max.points= 500000 \
     set.max.neighbor.ratio= 1e6

refinebox name= Ref_golbal \
    min="0 0" max="5 4.45" \
    refine.min.edge= "0.01 0.1" \
    refine.max.edge= "0.1  0.2" \
    refine.fields= { NetActive } def.max.asinhdiff= 1.0 \
    adaptive materials= { Silicon }

refinebox name= Ref_SD \
    min="0 0" max="0.3 1.0" \
    refine.min.edge= "0.01 0.05" \
    refine.max.edge= "0.02  0.1" \
    refine.fields= { NetActive } def.max.asinhdiff= 1.0 \
    adaptive materials= { Silicon }

refinebox name= Ref_CT Silicon \
    min="-0.1 0" max="0.02 4.45" \
    min.normal.size= 0.005 normal.growth.ratio= 1.3 \
    interface.materials= { Tungsten Silicon }

    
    
refinebox name= Ref_CHA Silicon \
    min="-0.01 0.9" max="0.015 4.0" \
    min.normal.size= 0.001 normal.growth.ratio= 1.3 \
    interface.materials= { Silicon Oxide }
      
grid remesh


select z= -1.0e20  name= NetActive store PolySilicon

#transform cut location= 0.55 left !remesh

contact name= "gate"   point x= -0.1 y= 1.5  Poly      replace
contact name= "source" point x= -0.1 y= 0.75  Tungsten  replace
#contact name= "substrate" box xlo= 1.5 xhi= 2.0 ylo= 0.558  yhi= 0.555  Silicon sidewall  
contact name= "drain"  point x= -0.1 y= 4.2  Tungsten  replace
contact name= "substrate" point x= -0.1 y= 0.25  Tungsten  replace
contact name= "body" bottom
struct tdr= n@node@ !Gas
exit
