#postheader

# unified Coordinate system
math coord.ucs
# uncomment following line, if you have 4 CPU or more.
math numThreads= 4

AdvancedCalibration

pdbSet ImplantData LeftBoundary Reflect
pdbSet ImplantData RightBoundary Reflect


# Disable stress re-balancing after etch/depo step
pdbSet Mechanics EtchDepoRelax 1
pdbSet ImplantData Extrude 1
pdbSet ImplantData DoseControl BeamDose 
pdbSet InfoDefault 1
pdbSet Oxide_Silicon Boundary BoundaryCondition ThreePhaseSegregation

#rem #---------------------------------------------------------------------#
#rem #   PARAMETERS & Initial boundary
#rem #---------------------------------------------------------------------#

fset Xtop 0

fset Lg @lgate@

fset Xbot 3
fset Xepi 1.5
fset Xj 1
fset GateThick 0.3

fset Lg2 [expr (0.5*@lgate@)]
fset LP2C 0.07
fset LCT 0.08
fset LCTe2AA 0.15
fset LSA [expr ($LP2C+$LCT+$LCTe2AA)]

fset Ymin 0
fset Ymax [expr ($Lg2+$LSA)]

fset PolyReox 0.002
fset Tox 0.027
fset f     1.0
fset Lsp1 0.05
fset Lsp2 0.12   

#endpostheader
#--------------------------------------#
## Initial Boundary
#--------------------------------------#

line x location= $Xtop tag= top
line x location= $Xbot tag= bottom
line y location= $Ymin tag= left
line y location= $Ymax tag= right

region Silicon substrate xlo= top xhi= bottom ylo= left yhi= right 
init concentration= 1e15 field= Boron wafer.orient= {0 0 1} flat.orient= {1 1 0}  

# -------------------------------------------------------------------- #
grid set.min.normal.size= 0.001/$f \
     set.normal.growth.ratio.2d= 2.0

refinebox name= Ref_global Silicon add  \
min= "0.0 -99.9" max="3.0 99.9"  \
xrefine= "0.02 0.5 " \
yrefine= "$f*$Ymax*0.1"

grid remesh


# ------------------------------------
#split @Well@
# ------------------------------------

##------------------------------------------------------------------
#----global mesh refine-------------------------
#--------------------------------------------------

	refinebox name= Ref_well Silicon add  \
	min= "0.0 -99.9" max="0.5 99.9"  \
	xrefine= "$f*0.02 $f*0.04 $f*$Xbot*0.06 " \
	yrefine= "$f*$Ymax*0.25"
 
	grid remesh

##-----Well oxide screen oxide-----------
deposit material= {Oxide} type= isotropic  thickness= 0.005

##------well implant--------

implant Boron dose= 1e13   energy= 250 tilt= 0 rotation= 0 
implant Boron dose= 1.5e13 energy= 160 tilt= 0 rotation= 0 
implant Boron dose= 2.4e12 energy= 25  tilt= 0 rotation= 0 

#----well anneal--------------------------------------------                                   
# -------------------------------------------------------------------- #
temp_ramp name= well time= 0.03   temp= 600.0  ramprate= 250.0
temp_ramp name= well time= 0.333  temp= 1050.0 ramprate= 0.0
temp_ramp name= well time= 0.083  temp= 1050.0 ramprate= -90.0

diffuse stress.relax temp_ramp= well

##---well screen oxide remove-------------------
etch type=cmp material= { all } coord=0.0
                    
# ------------------------------------
#split @Poly@
# ------------------------------------

## ---------- gate oxidation --------------------------------------
deposit material= {Oxide} type= isotropic  rate= {1.0} time= $Tox

temp_ramp name= gateox time= 24 temp= 600.0 ramprate= 0.0972
temp_ramp name= gateox time= 20 temp= 740.0 ramprate= 0.0
temp_ramp name= gateox time= 5.6<s> temp= 740.0 ramprate= -25.0
diffuse stress.relax temp_ramp= gateox

##-----Poly mask define--------------------
mask name=GATE left=$Ymin right=$Lg2  negative
# ---- poly silicon deposition,pre-doping and etching --------
deposit material= {Poly} type= anisotropic  thickness= $GateThick

##------Poly etching----------------
photo mask=GATE thickness=0.1
etch material= {Poly} type= anisotropic rate= { $GateThick } time=1.1

strip photoresist

## ---------- reoxidation -----------------------------------------
deposit material= {Oxide} type= isotropic  rate= { $PolyReox } time= 1.0

## ---------- PolyReox spacer etching --------------------------------
etch material= {Oxide} type= anisotropic rate= { $PolyReox } time= 1.5
deposit nitride isotropic thickness= 0.01
etch nitride anisotropic thickness= 0.015

# ------------------------------------
#split @HaloLDD@
# ------------------------------------

# --- refinebox for halo implants ----------------------- #
	refinebox name= Ref_LDD Silicon   \
	min= "0.0 $Lg2-0.1" max="$Xj+0.1 $Ymax"  \
	xrefine= "$f*0.005  $f*0.05 " \
	yrefine= "$f*0.02" 
 
	grid remesh
	
##------LDD implant screen ox------
deposit material= {Oxide} type= anisotropic   rate= { 0.002 } time= 1.0


# --- ldd implantation ---

implant Phosphorus dose= @dLDD@ energy= @eLDD@ tilt= @tLDD@ rotation= 0 mult.rot= 4 

diffuse temperature= 950 time= 3<s>

#split @Spacer@
# -------------------------------------------------------------------- #
## ---------- side wall spacer -----------------------------------

deposit material= {Oxide} type= isotropic rate= {1.0} time= $Lsp1        
deposit material= {Nitride} type= isotropic rate= {1.0} time= $Lsp2

etch material= {Nitride} type= anisotropic rate= 1.8*$Lsp2 time= 1.0
etch material= {Oxide} type= anisotropic rate= 1.4*$Lsp1 time= 1.0

#split @SD@

# --- source/drain-implantation ---

implant Phosphorus dose= 3.5e14 energy= 35 tilt= 0 rotation= 0 
implant Arsenic dose= 1.5e15 energy= 25 tilt= 0 rotation= 0

## -------Spike+laser annealing-----------------
temp_ramp name= spike time= 0.025  temp= 600  ramprate= 300.0
temp_ramp name= spike time= 0.01   temp= 1050 ramprate= 0.0
temp_ramp name= spike time= 0.05   temp= 1050 ramprate= -150.0
diffuse temp_ramp= spike

#split @Mesh@
# -------------------------------------------------------------------- #
# Re-Meshing for Device Simulation
# -------------------------------------------------------------------- #
etch material= {Oxide} type= anisotropic rate= 0.015 time= 1.0     

select z= 1.0e20  name= NetActive store PolySilicon

##---------------Remeshing for device simulation--------##
# clear the process simulation mesh
refinebox clear
line clear

# Mesh Multiplication factor for device
set fd 1.0

# Set very high values for adaptive meshing parameters
pdbSet Grid AdaptiveField Refine.Abs.Error 1e37
pdbSet Grid AdaptiveField Refine.Rel.Error 1e10
pdbSet Grid AdaptiveField Refine.Target.Length 100.0

# Set high quality delaunay meshes
pdbSet Grid SnMesh DelaunayType boxmethod
pdbSet Grid SnMesh CoplanarityAngle 179
pdbSet Grid SnMesh MaxPoints 500000
pdbSet Grid SnMesh MaxNeighborRatio 1e6
                                              
# Set the interface spacing
pdbSet Grid SnMesh max.box.angle.2d 179
grid set.min.normal.size= 0.002/$fd \
     set.normal.growth.ratio.2d= 4.0 \
     set.max.points= 500000 \
     set.max.neighbor.ratio= 1e6

####-----------refine for device simulation------------

	refinebox name= Global_Si Silicon\
	min= "-0.3 -99.9" max="3.0 99.9"  \
	xrefine= "$f*0.01 $f*0.1 " \
	yrefine= "0.5 0.1" 
	                                                           
	refinebox name= Channel_punch Silicon adaptive \
	min= {-0.001 $Lg2-0.2 } \
	max= {0.4 $Lg2+0.4 }  \
	refine.fields= { NetActive } def.max.asinhdiff= 1.0 \
	refine.min.edge= "$f*0.002 $f*0.02 " \
	refine.max.edge= "$f*0.01 $f*0.02 " 
	
    refinebox name= Channel Silicon \
	min= "-0.001 $Ymin" max="0.02 $Lg+0.1"  \
	xrefine= "$f*0.001 $f*0.005 " \
	yrefine= "0.25 0.05"                        

    refinebox name= SD Silicon \
	min= "-0.001 $Ymax-0.25" max="0.02 $Ymax"  \
	xrefine= "$f*0.001 $f*0.002 " \
	yrefine= "0.002" 	
	
	refinebox name= ChannelIF interface.materials= {Silicon} \
	min= "-0.001 $Ymin" max="0.02 $Lg+0.1"  \
    min.normal.size= $f*0.001 normal.growth.ratio= 1.3  
    
    grid remesh

# Contacts

transform reflect left !remesh

#contact name= "gate"    box xlo= -$GateThick xhi= -$GateThick-0.02 ylo= -$Lg2+0.01 yhi= $Lg-0.01 PolySilicon  add
contact name= "gate"   point x= -$GateThick*0.5 y= 0.0  PolySilicon  add
contact name= "drain"   box xlo= -0.001 xhi= 0.001 ylo= $Ymax-0.1 yhi= $Ymax-0.02 Silicon  add
contact name= "source"  box xlo= -0.001 xhi= 0.001 ylo= -$Ymax+0.1 yhi= -$Ymax+0.02 Silicon  add
contact name= Substrate bottom

struct tdr= n@node@ !Gas

exit
