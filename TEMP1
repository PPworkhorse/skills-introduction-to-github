	eGradQuasiFermi/Vector hGradQuasiFermi/Vector
	eEparallel hEparallel eENormal hENormal
	BandGap
	BandGapNarrowing
	Affinity
	ConductionBand ValenceBand
	eTrappedCharge hTrappedCharge
	*--Stress related data
	StressXX StressYY StressZZ StressXY StressXZ StressYZ
	eMobilityStressFactorXX eMobilityStressFactorYY eMobilityStressFactorZZ
	eMobilityStressFactorXY eMobilityStressFactorXZ eMobilityStressFactorXY
	hMobilityStressFactorXX hMobilityStressFactorYY hMobilityStressFactorZZ
	hMobilityStressFactorYZ hMobilityStressFactorXZ hMobilityStressFactorXY
}


Math {
  Extrapolate
  RelErrControl
  Digits= 5
  Notdamped= 50
  Iterations= 15
  RHSmin= 1e-8
  Method= Pardiso	  
  DirectCurrent
  ExitOnFailure
  TensorGridAniso
  StressMobilityDependence = TensorFactor
  Number_of_Threads= 8 
  RefDens_eGradQuasiFermi_Zero= 1e12
  RefDens_hGradQuasiFermi_Zero= 1e12
  -CheckUndefinedModels	  
	* Please uncomment if you have 4 CPUs or more
	Number_of_Threads= 4
}

Solve {
	*- Creating initial guess:
	NewCurrentPrefix="n@node@_init"
	Coupled(Iterations= 1000 LineSearchDamping= 1e-8){ Poisson }
	Coupled { Poisson _CAR_ }

	*- Vg sweep
	NewCurrentPrefix="BVD_"
	Quasistationary(
##		BreakCriteria { Current(contact="drain" AbsVal= 2.0e-13) }
		DoZero
		InitialStep= 1e-3 Increment= 1.35
		MinStep= 1e-6 MaxStep= 0.1
		Goal { Name="drain" Voltage= 12.0 }
	){ Coupled { Poisson Electron Hole }
		CurrentPlot( Time=(Range=(0 1) Intervals= 120)  )
	}
}
