### Lonten N150V Cell

math coord.ucs
AdvancedCalibration

pdbSet ImplantData LeftBoundary  Reflect
pdbSet ImplantData RightBoundary Reflect

pdbSet ImplantData DoseControl BeamDose
pdbSet Oxide_Silicon Boundary BoundaryCondition ThreePhaseSegregation

fset Fastmode 0
if { $Fastmode == 1} {
    pdbSet ImplantData NoImplant 1
    pdbSet Diffuse NoDiffusionReaction 1
}

math numThreads= 8


##-------------------------------------
line y location=0 spacing=0.1 tag=left
line y location=@PITCH@*10 spacing=0.5 tag=right
line x location=0 spacing=0.5 tag=top
line x location=9 spacing=1 
line x location=10 spacing=1 tag=bottom

region silicon xlo= top xhi= bottom ylo= left yhi= right
init resistivity= 0.1 field= Arsenic wafer.orient= 100 flat.orient= {1 1 0}

############EPI DEP###################
#split EPI

grid set.min.normal.size= 0.01 \
     set.normal.growth.ratio.2d= 2.0 \
     set.max.points= 1000000 set.max.neighbor.ratio= 1e6

refinebox name=Global Silicon       \
    min= "0 0" max= "10 50"  \
    xrefine= "0.01 1.0 "                   \
    yrefine= "0.5 0.5"

grid remesh

etch Silicon type=anisotropic thickness= @EPITHK@
deposit Silicon type= anisotropic thickness= @EPITHK@  fields.values= {Phosphorus= @CEPI@} temperature= 600
diffuse  temp=1100 time= 1e-6<s>

#split TR
mask name=TR segments= {@PITCH@*0.5-@TRCD@*0.5+0.1  @PITCH@*0.5+@TRCD@*0.5-0.1    @PITCH@*0.5-@TRCD@*0.5+2.9  @PITCH@*0.5+@TRCD@*0.5+2.7   \
                        @PITCH@*0.5-@TRCD@*0.5+5.7  @PITCH@*0.5+@TRCD@*0.5+5.5    @PITCH@*0.5-@TRCD@*0.5+8.5  @PITCH@*0.5+@TRCD@*0.5+8.3   \
                        @PITCH@*0.5-@TRCD@*0.5+11.3  @PITCH@*0.5+@TRCD@*0.5+11.1    @PITCH@*0.5-@TRCD@*0.5+14.1  @PITCH@*0.5+@TRCD@*0.5+13.9 }

photo mask=TR  thickness=2<um>

etch silicon trapezoidal thickness=@TRDEP@ angle=89
etch silicon thickness=0.2 type=isotropic 
strip photoresist

etch oxide thickness=3 type=anisotropic   

#split FOXTHK
############FOX 4500A###################

refinebox name= ALL materials= {Silicon} min= {0.0 0.0} max= {10 25}  xrefine= {0.1 0.5}  yrefine= {0.5 0.5}
                                                                                                      
refinebox name= Ref_IF Silicon \
    min="-1 0" max="10.0 30" \
    min.normal.size= 0.05 normal.growth.ratio= 1.5 \
    interface.materials= { Silicon Oxide }  

refinebox name= top_refine materials= {Silicon} min= {0.0 0.0} max= {1.3 25.0}  xrefine= {0.03 0.06 0.03}  yrefine= {0.25 0.25}

grid remesh                                                     

etch Nitride thickness=0.65 type=isotropic
deposit oxide thickness=@FOXTHK@ 

#split S_poly
############################################# SOURCE POLY ###############
mask name= m_S_poly  segments= {0 @PITCH@*0.5-@TRCD@*0.5+8  }
deposit polysilicon thickness=2.8  arsenic concentration=1e20 temperature=540
etch polysilicon thickness=3.2

photo mask=m_S_poly  thickness=3<um>
etch polysilicon thickness= 1.35
strip photoresist

#split HDP
############################################# HDP ###############
mask name= m_HDP  segments= {0 @PITCH@*0.5-@TRCD@*0.5+4.50  }
deposit oxide thickness=2.8

etch oxide thickness=3.0 isotropic
etch oxide cmp coord=0
etch oxide thickness=0.03 type=isotropic

photo mask=m_HDP  thickness=3<um>
etch oxide thickness=1.3
strip photoresist

#split GOX
deposit oxide thickness=@GOX@ isotropic

#split G_poly
################################### GATE POLY ##############################

deposit polysilicon thickness=2.4  arsenic concentration=1e20  temperature=540
etch    polysilicon    thickness=2.42

#split PBI
######################################## PBODY #################################

implant boron dose=@PBI@ energy=200 tilt=7 rotation=90 
diffuse  temp= 1100 time= 30<s> flowN2=20 

#split BM
######################################## body#################################
mask name=BM left=1.95  right=@BM@ 
photo mask=BM  thickness=0.6<um> 
implant boron dose=@PBI1@ energy=100 tilt=7 rotation=90 
diffuse  temp=1100 time= 30<s> flowN2=20 
strip photoresist

#split NSDIMP
mask name=SN  segments= {0  4} 
photo mask=SN  thickness=3.5<um> 
implant    Arsenic dose=@NSDIMP@ energy=130  tilt=7 rotation=90 
strip photoresist

diffuse 	time=0.05 temp=950 flowN2=16

#split BPSG
####################################BPSG8000-8000A
deposit oxide thickness=0.22
deposit oxide thickness=0.6

#split CTCD
####################################################################################pplus

mask name= CT   segments= {0 0.14    2.5 2.8     5.3 5.6     8.1 8.4      9.5 9.8     12.3 12.6       15.1 15.4 }
photo mask=CT  thickness=3<um> 

etch oxide thickness=1 type=anisotropic
etch silicon thickness=0.26 type=anisotropic
etch polysilicon thickness=0.125 type=anisotropic
strip photoresist

#split CTIMP
##########################################pplus

implant    BF2 dose=@CTIMP@ energy=30 tilt=0 rotation=90      
diffuse  time= 0.05  temp= 1000   flowN2=16

####################################################################################contact
deposit aluminum thickness=4.1

#split DEVICE

############################################
contact name=gate x=0.1 y=1.2 replace point
contact name=gate1 x=0.1 y=4.0  replace point
contact name=source x=-2 y=1.0  replace point
contact name=source1 x=4.0 y=1.25 replace point
contact name=source2 x=4.0 y=4.0 replace point
contact name=source3 x=4.0 y=7.0 replace point

contact name=drain bottom 
struct tdr=n@node@_#25final

#split RMESH
refinebox clear
refinebox !keep.lines
line clear

pdbSet Grid AdaptiveField Refine.Abs.Error     1e37
pdbSet Grid AdaptiveField Refine.Rel.Error     1e10
pdbSet Grid AdaptiveField Refine.Target.Length 100.0
pdbSet Grid Adaptive 1
pdbSet Grid SnMesh DelaunayType boxmethod

refinebox name= Substrate \
   refine.max.edge= "0.5  0.5" \
   refine.min.edge= "0.05 0.05" \
   refine.fields= { NetActive } def.max.asinhdiff= 0.5 \
   adaptive silicon add
  
   
refinebox name= trench_Interface \
   min= "0 0" \
   max= "@<0.06+0.4>@ @PITCH@" \
   min.normal.size= 0.01 normal.growth.ratio= 2.0 \
   max.lateral.size= 1 \
   interface.materials= {Silicon } all add
   
refinebox name= ct_Interface_1 Silicon \
   min= "0 0.3" \
   max= "@<0.2+0.1>@ 0.7" \
   xrefine= {0.03  } yrefine= {0.03  }
   

refinebox name= ct_Interface_2 Silicon \
   min= "0 3.3" \
  max= "@<0.2+0.1>@ 3.7" \
  xrefine= {0.03  } yrefine= {0.03  }


refinebox name= poly_Interface \
   min= "0 0" \
  max= "@<0.06+0.4>@ @PITCH@" \
   min.normal.size= 0.1 normal.growth.ratio= 2.0 \
   max.lateral.size= 1 \
   interface.materials= {PolySilicon} all add
   
refinebox silicon    min= "0 0" \
   max= "@<0.06+0.4>@ @PITCH@" \
  xrefine= {0.25  }  yrefine= { 0.25 }  add 

refinebox name= Ref_IF Silicon \
    min="-1 0" max="10.0 30" \
    min.normal.size= 0.002 normal.growth.ratio= 1.3 \
    interface.materials= { Silicon Oxide }  
                                              
refinebox remesh  
struct tdr=n@node@                      
