def TrendPlot_add_px(data,x,y1,y2,color,symbol,xlabel,ylabel,title,fit='ols',log_y=False):
    if fit=='ols' or 'lowess':
        fig=px.scatter(data,x=x,y=y,color=color,symbol=symbol,trendline=fit,width=900,height=600,template='seaborn',log_y=log_y)
    elif fit== 'no':
        fig=px.scatter(data,x=x,y=y,color=color,symbol=symbol,width=900,height=600,template='seaborn',log_y=log_y)

    help_fig=px.scatter(data,x=x,y=y2,trendline='lowess')
    x_trend = help_fig['data'][1]['x']
    y_trend = help_fig['data'][1]['y']

    fig.add_trace(go.Scatter(x=x_trend,y=y_trend,mode='lines',marker_color='gray',showlegend=False))
    
    fig.update_traces(marker_size=20,line_dash='dashdot',line_shape='spline',line_smoothing=1.0)
    fig.update_xaxes(showgrid=True,gridcolor='lightgray',exponentformat= 'e')
    fig.update_yaxes(showgrid=True,gridcolor='lightgray')
    fig.update_layout(xaxis_title=xlabel,
                      yaxis_title=ylabel,
                      title=title, title_y=0.95,
                      font_size=20,
                      legend=dict(x=1.0,y=1.0,font_size=12,bgcolor='rgba(0,0,0,0)')
                 )
    return fig

