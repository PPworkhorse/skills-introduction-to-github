                      yaxis_title=ylabel,
                      title=title, title_y=0.95,
                      font_size=20,
                      legend=dict(x=1.0,y=1.0,font_size=12,bgcolor='rgba(0,0,0,0)')
                 )
    return fig

def ScatterF_px(data,x,y,color,symbol,facet,xlabel,ylabel,title,log_y=False):
    
    fig=px.scatter(data,x=x,y=y,color=color,symbol=symbol,facet_col=facet,width=900,height=600,template='seaborn',log_y=log_y)

    fig.update_traces(marker_size=20, mode='lines+markers')
    fig.update_xaxes(showgrid=True,gridcolor='lightgray')
    fig.update_yaxes(showgrid=True,gridcolor='lightgray')
    fig.update_layout(xaxis_title=xlabel,
                      yaxis_title=ylabel,
                      title=title, title_y=0.95,
                      font_size=20,
                      legend=dict(x=1.0,y=1.0,font_size=12,bgcolor='rgba(0,0,0,0)',traceorder='normal')
                 )
    return fig
    
def Contour_px(data,x,y,z,xlabel,ylabel,title,colortitle):
    df=data.pivot(index=x,columns=y,values=z)
    x1=df.index.values
    y1=df.columns.values
    z1=df.values
    fig=go.Figure(data=[go.Contour(x=y1,y=x1,z=z1,colorscale='RdYlGn', contours=dict(showlabels=True),colorbar=dict(title=colortitle))])
    fig.update_xaxes(showgrid=True,gridcolor='lightgray')
    fig.update_yaxes(showgrid=True,gridcolor='lightgray')
    fig.update_layout(xaxis_title=xlabel,
                      yaxis_title=ylabel,
                      title=title, title_y=0.95,
                      font_size=20,
                      legend=dict(x=1.0,y=1.0,font_size=12,bgcolor='rgba(0,0,0,0)',traceorder='normal')
                 )
    return fig    

